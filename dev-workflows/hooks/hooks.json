{
  "version": 1,
  "description": "dev-workflows plugin hooks — completion notification, git context injection on impl:/vuln:/upgrade: prompts, and test-run notification.",
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "bash": "bash ${PLUGIN_ROOT}/hooks/notify-done.sh"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "bash": "bash ${PLUGIN_ROOT}/hooks/preload-context.sh"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "bash": "bash ${PLUGIN_ROOT}/hooks/test-notify.sh"
      }
    ]
  }
}
